<?xml version="1.0" encoding="UTF-8"?>
<!--
 ============================================================================
 TICKET-ADV012 / TICKET-ADV013 / TICKET-ADV014 — first changeset + rollback + preconditions
 WHAT:    Initial DB setup: ensure databasechangelog is the only Liquibase
          artefact at first run. Demonstrates rollback tags and preconditions.
 HOW:     One <changeSet> per logical step. <rollback> defines the reverse
          op (so `liquibase rollbackCount 1` actually works).
 WHY:     Without rollback definitions every changeset is one-way. Without
          preconditions a re-run on a half-applied DB will fail loudly.
 OBSERVE: After boot, `SELECT * FROM databasechangelog` shows id=001-init.
 ============================================================================
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-init-tag" author="trainer">
        <tagDatabase tag="v1.0.0-init"/>
    </changeSet>

</databaseChangeLog>
