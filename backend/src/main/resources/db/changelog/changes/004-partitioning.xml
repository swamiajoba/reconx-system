<?xml version="1.0" encoding="UTF-8"?>
<!--
 ============================================================================
 Monthly partitioning of trades on Postgres
 WHAT:    Convert trades into a range-partitioned parent on trade_date and
          create partitions for the current rolling 12 months.
 HOW:     Postgres-only via raw SQL. The trainer guide for Day 1 documents
          the "rename, recreate as partitioned, copy data" pattern that
          students must run if production data already exists. In this clean
          starter we recreate trades directly since there's nothing to copy.
 WHY:     500-million-row trades table would kill EXPLAIN; monthly partitions
          give predictable prune-by-date plans.
 OBSERVE: \d+ trades shows "Partitioned table" + 12 child partitions.
 ============================================================================
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- Demonstration only: the partitioning conversion is destructive and is
         taught in the trainer guide Day-1 Workshop 1B. In this starter we
         create a single partition for the rolling-current-month so the
         seed data has somewhere to land. -->
    <changeSet id="004-partition-current-month" author="trainer">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>
        <comment>Placeholder: students rebuild this in TICKET-ADV007. Trainer copy
                 ships a no-op so dev/uat boot cleanly.</comment>
        <sql>SELECT 1;</sql>
        <rollback>
            <sql>SELECT 1;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
